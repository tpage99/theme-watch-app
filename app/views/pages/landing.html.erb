    </div>
  </div>
</nav>

<!-- Hero -->
<section class="relative min-h-[90vh] flex items-center gradient-mesh border-grid">
  <div class="max-w-5xl mx-auto px-6 pt-28 pb-20">
    <div class="max-w-2xl">

      <!-- Badge -->
      <div class="animate-fade-up inline-flex items-center gap-2 px-3 py-1 rounded-full border border-tw-700/40 bg-tw-900/50 text-xs font-medium text-tw-400 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-tw-400 animate-pulse"></span>
        Coming soon. Join the waitlist.
      </div>

      <!-- Headline -->
      <h1 class="animate-fade-up delay-1 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] text-white">
        Know when Shopify themes change
        <span class="text-tw-400"> before your merchants do.</span>
      </h1>

      <!-- Subhead -->
      <p class="animate-fade-up delay-2 mt-6 text-lg sm:text-xl text-white/50 leading-relaxed max-w-lg">
        Theme compatibility tracking for Shopify app developers. Version alerts, compatibility management, and verified app profiles across 1,100+ Shopify themes.
      </p>

      <!-- CTA -->
      <div id="waitlist" class="animate-fade-up delay-3 mt-10 scroll-mt-24">
        <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-md" data-controller="waitlist">
          <input
            type="email"
            name="email"
            required
            placeholder="you@yourapp.com"
            class="cta-input flex-1 py-5 sm:py-3 px-5 sm:px-4 rounded-xl sm:rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-white/30 text-lg sm:text-sm focus:outline-none focus:border-tw-500 transition-all"
          >
          <button
            type="submit"
            class="py-5 sm:py-3 px-6 rounded-xl sm:rounded-lg bg-tw-500 hover:bg-tw-400 text-tw-950 font-semibold text-lg sm:text-sm transition-colors whitespace-nowrap cursor-pointer"
          >
            Join waitlist
          </button>
        </form>
        <p class="mt-3 text-xs text-white/25">No spam. One email when we start accepting apps.</p>

        <!-- Success state (hidden by default) -->
        <div id="waitlist-success" class="hidden mt-4 px-4 py-3 rounded-lg bg-tw-500/10 border border-tw-500/20">
          <p class="text-sm text-tw-400 font-medium">You're on the list. We'll be in touch.</p>
        </div>
      </div>

    </div>
  </div>
</section>

