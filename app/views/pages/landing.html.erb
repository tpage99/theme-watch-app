<% content_for :head do %>
  <meta name="description" content="Know when Shopify themes change before your merchants do. Track compatibility across 1,100+ Shopify themes, get version alerts, and show up as a verified app on shopinfo.app.">
  <meta property="og:title" content="theme.watch | For Shopify App Developers">
  <meta property="og:description" content="Theme compatibility tracking, version alerts, and public app profiles. Know when themes change before your merchants report it.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://theme.watch">
  <link rel="canonical" href="https://theme.watch">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "theme.watch",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "description": "Theme compatibility tracking for Shopify app developers. Version alerts, compatibility management, and verified app profiles across 1,100+ Shopify themes.",
    "url": "https://theme.watch",
    "offers": {
      "@type": "Offer",
      "price": "39",
      "priceCurrency": "USD",
      "priceValidUntil": "2027-12-31"
    },
    "creator": {
      "@type": "Organization",
      "name": "The Pages Media",
      "url": "https://shopinfo.app"
    }
  }
  </script>
<% end %>

<div class="grain"></div>

<!-- Nav -->
<nav class="fixed top-0 w-full z-40 backdrop-blur-md bg-tw-950/80 border-b border-white/5">
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-7 h-7 rounded-md bg-tw-500 flex items-center justify-center">
        <svg class="w-4 h-4 text-tw-950" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      </div>
      <span class="font-semibold text-sm tracking-tight">theme.watch</span>
    </a>
    <div class="flex items-center gap-6">
      <a href="#features" class="text-sm text-white/50 hover:text-white/80 transition-colors">Features</a>
      <a href="#how-it-works" class="text-sm text-white/50 hover:text-white/80 transition-colors">How It Works</a>
      <a href="#pricing" class="text-sm text-white/50 hover:text-white/80 transition-colors">Pricing</a>
      <a href="#waitlist" class="text-sm text-tw-400 hover:text-tw-300 transition-colors font-medium">
        Join waitlist &rarr;
