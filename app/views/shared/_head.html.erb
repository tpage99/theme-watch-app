<title><%= content_for(:title) || "theme.watch | Theme Compatibility Tracking for Shopify App Developers" %></title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= yield :head %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
<%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

<% if ENV["CLERK_PUBLISHABLE_KEY"].present? && ENV["CLERK_FRONTEND_API"].present? %>
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= ENV["CLERK_PUBLISHABLE_KEY"] %>"
    src="<%= ENV["CLERK_FRONTEND_API"].chomp("/") %>/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
<% end %>

<!-- Fathom -->
<script src="https://cdn.usefathom.com/script.js" data-site="MQALLHXM" defer></script>
